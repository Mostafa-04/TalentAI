#!/bin/sh
# Format all code before pushing

echo "Auto-formatting before push..."

# Format PHP with Laravel Pint
./vendor/bin/pint

# Format frontend with Prettier
npm run format

# If formatting made changes, stage and amend them into the push
if ! git diff --quiet; then
    git add -A
    git commit -m "style: auto-format code"
    echo "Formatting changes committed."
fi
